---
const year = new Date().getFullYear();
---

<footer class="footer">
  <span class="footer__copy">© {year} John Muhlenberg</span>
  <span class="footer__copy">Sales Engineer · Recharge</span>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 1.5rem 3rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .footer__copy {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--text-muted);
    text-transform: uppercase;
  }
</style>