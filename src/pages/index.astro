---
import BaseLayout from '../layouts/BaseLayout.astro';

const marqueeItems = [
  'Subscription Infrastructure', 'Technical Discovery', 'Merchant Growth',
  'Business Strategy', 'SaaS Retention', 'Revenue Architecture',
  'API Integration', 'Custom Code Projects',
];
const allItems = [...marqueeItems, ...marqueeItems];
---

<BaseLayout title="John Muhlenberg — Sales Engineer" activePage="home">

  <section class="hero grid-overlay">
    <h1 class="sr-only">John Muhlenberg — Sales Engineer at Recharge</h1>
    <p class="hero__eyebrow animate-fade-up animate-fade-up--delay-1">Sales Engineer · Recharge</p>
    <p class="hero__name animate-fade-up animate-fade-up--delay-2">John Muhlenberg</p>
    <h2 class="hero__headline animate-fade-up animate-fade-up--delay-3">
      I help merchants stop<br>guessing and start <em>growing.</em>
    </h2>
    <p class="hero__sub animate-fade-up animate-fade-up--delay-4">
      I sit at the intersection of technical depth and commercial clarity —
      translating complex subscription infrastructure into decisions that
      actually move revenue.
    </p>
    <div class="hero__actions animate-fade-up animate-fade-up--delay-4">
      <a href="/work" class="btn-primary">See my work</a>
      <a href="/writing" class="btn-secondary">Read my thinking <span class="arrow">→</span></a>
    </div>
    <div class="hero__role-tag">
      <span class="mono-label">Currently at</span>
      <strong>Recharge</strong>
      <div class="role-line"></div>
      <span class="mono-label">Based in</span>
      <strong>Denver, CO</strong>
    </div>
  </section>

  <div class="marquee-strip">
    <div class="marquee-track">
      {allItems.map(item => (
        <span class="marquee-item">
          <span class="marquee-dot"></span>
          {item}
        </span>
      ))}
    </div>
  </div>

  <section class="preview">
    <div class="preview-grid">
      <a href="/thinking" class="preview-card">
        <p class="preview-card__num">01 — Frameworks</p>
        <h2 class="preview-card__title">How I Think</h2>
        <p class="preview-card__desc">The mental models I use for discovery, technical evaluation, and translating complexity into commercial clarity.</p>
        <span class="preview-card__cta">Explore frameworks →</span>
      </a>
      <a href="/work" class="preview-card">
        <p class="preview-card__num">02 — Case Studies</p>
        <h2 class="preview-card__title">Work</h2>
        <p class="preview-card__desc">Projects and wins — each written as a real case study. Problem, approach, outcome, and what I'd do differently.</p>
        <span class="preview-card__cta">See the work →</span>
      </a>
      <a href="/writing" class="preview-card">
        <p class="preview-card__num">03 — Writing</p>
        <h2 class="preview-card__title">Writing</h2>
        <p class="preview-card__desc">Business strategy through the lens of an SE. Subscription economics, merchant behaviour, and ideas I can't stop thinking about.</p>
        <span class="preview-card__cta">Read the blog →</span>
      </a>
    </div>
  </section>

  <div class="footer-cta">
    <p class="footer-cta__text">
      Have a problem worth<br><em>talking through?</em>
    </p>
    <div class="footer-cta__links">
      <a href="https://www.linkedin.com/in/jwmuhlenberg/" target="_blank" rel="noopener" class="footer-cta__link">LinkedIn ↗</a>
      <a href="https://github.com/jmuhlenberg" target="_blank" rel="noopener" class="footer-cta__link">GitHub ↗</a>
      <a href="mailto:jmuhlenberg16@yahoo.com" class="footer-cta__link">Email ↗</a>
    </div>
  </div>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 10rem 3rem 6rem;
    z-index: 1;
    overflow: hidden;
  }
  .hero__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 2rem;
  }
  .hero__name {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--text-secondary);
    margin-bottom: 1.25rem;
  }
  .hero__headline {
    font-family: var(--font-serif);
    font-size: clamp(3.5rem, 7vw, 6.5rem);
    line-height: 1.02;
    letter-spacing: -0.03em;
    max-width: 900px;
    margin-bottom: 2.5rem;
  }
  .hero__headline em { font-style: italic; color: var(--accent); }
  .hero__sub {
    font-size: 1.05rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 540px;
    margin-bottom: 3.5rem;
  }
  .hero__actions {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .arrow { display: inline-block; transition: transform 0.2s; }
  .btn-secondary:hover .arrow { transform: translateX(4px); }
  .hero__role-tag {
    position: absolute;
    right: 3rem;
    bottom: 6rem;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.5rem;
  }
  .hero__role-tag strong {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-secondary);
    font-weight: 500;
  }
  .role-line { width: 40px; height: 1px; background: var(--border); }

  /* Marquee */
  .marquee-strip {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    padding: 1rem 0;
    background: var(--surface);
  }
  .marquee-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: marquee 28s linear infinite;
  }
  .marquee-item {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .marquee-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* Preview cards */
  .preview {
    position: relative;
    z-index: 1;
    padding: 6rem 3rem;
  }
  .preview-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1.5px;
    background: var(--border);
    border: 1px solid var(--border);
  }
  .preview-card {
    background: var(--surface);
    padding: 2.5rem;
    display: block;
    transition: background 0.25s;
    position: relative;
    overflow: hidden;
  }
  .preview-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 0;
    background: var(--accent);
    transition: height 0.3s ease;
  }
  .preview-card:hover { background: var(--surface-2); }
  .preview-card:hover::before { height: 100%; }
  .preview-card__num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 2.5rem;
  }
  .preview-card__title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    line-height: 1.15;
    color: var(--text-primary);
    margin-bottom: 1rem;
  }
  .preview-card__desc {
    font-size: 0.85rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2rem;
  }
  .preview-card__cta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
  }

  /* Footer CTA */
  .footer-cta {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--border);
    padding: 5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .footer-cta__text {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.2;
  }
  .footer-cta__text em { font-style: italic; color: var(--accent); }
  .footer-cta__links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }
  .footer-cta__link {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    transition: color 0.2s;
  }
  .footer-cta__link:hover { color: var(--accent); }
</style>