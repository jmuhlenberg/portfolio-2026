---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const cases = [
  {
    num: '01',
    slug: 'mill',
    client: 'Mill',
    eyebrow: 'Enterprise · Hardware subscription architecture',
    type: 'Rental model, delayed billing, and a buyout flow built from scratch',
    tags: ['Solution architecture', 'API design', 'Enterprise', 'Hardware'],
    featured: true,
  },
  {
    num: '02',
    slug: 'nectar-hydration',
    client: 'Nectar Hydration',
    eyebrow: 'Mid-market · Subscription migration',
    type: 'White glove VIP migration — pre-sales through frontend delivery',
    tags: ['Migration', 'Frontend dev', 'Biz strategy', 'Mid-market'],
    featured: false,
  },
  {
    num: '03',
    slug: 'faster-way',
    client: 'FASTer Way to Fat Loss',
    eyebrow: 'Enterprise · Complex migration & architecture',
    type: 'Multi-system orchestration across a coach-driven subscription platform',
    tags: ['API / webhooks', 'Solution architecture', 'Enterprise', 'Co-sell'],
    featured: false,
  },
  {
    num: '04',
    slug: 'prn-vision',
    client: 'PRN Vision',
    eyebrow: 'Enterprise · Multi-storefront unification',
    type: 'Two-brand healthcare migration with a legacy Cybersource payment gateway',
    tags: ['Multi-brand', 'Payment migration', 'Enterprise', 'Co-sell'],
    featured: false,
  },
];
---

<BaseLayout title="Work — JWM" activePage="work">

  <header class="page-header grid-overlay">
    <p class="eyebrow">Case studies</p>
    <h1 class="page-title">The <em>work</em></h1>
    <p class="page-desc">Four projects, written honestly — what the problem was, how I approached it, what I'd do differently. The goal isn't to impress. It's to give you a real sense of how I think and what it's like to work with me.</p>
  </header>

  <div class="case-index">
    {cases.map(c => (
      <a href={`${base}work/${c.slug}`} class:list={['index-card', { featured: c.featured }]}>
        <p class="index-num">{c.num}{c.featured ? ' — Featured' : ''}</p>
        <div class="index-card-body">
          <p class="index-eyebrow">{c.eyebrow}</p>
          <p class="index-client">{c.client}</p>
          <p class="index-type">{c.type}</p>
          <div class="index-tags">
            {c.tags.map(t => <span class="tag">{t}</span>)}
          </div>
        </div>
        <span class="index-arrow">→</span>
      </a>
    ))}
  </div>

</BaseLayout>

<style>
  .page-header {
    padding: 8rem 3rem 4rem;
    border-bottom: 1px solid var(--border);
  }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .page-title {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 1.5rem;
  }
  .page-title em { font-style: italic; color: var(--accent); }
  .page-desc {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.8;
    color: var(--text-secondary);
    max-width: 520px;
  }

  .case-index {
    display: flex;
    flex-direction: column;
  }

  .index-card {
    display: grid;
    grid-template-columns: 5rem 1fr auto;
    gap: 2rem;
    align-items: center;
    padding: 2.5rem 3rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
    transition: background 0.15s;
  }
  .index-card:hover { background: rgba(255,255,255,0.02); }
  .index-card.featured { background: rgba(255,255,255,0.015); }

  .index-num {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .index-card-body { display: flex; flex-direction: column; gap: 0.4rem; }
  .index-eyebrow {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .index-client {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }
  .index-type {
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--text-secondary);
    max-width: 480px;
  }
  .index-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.4rem;
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.2rem 0.5rem;
  }

  .index-arrow {
    font-size: 1.1rem;
    color: var(--text-muted);
    transition: color 0.15s, transform 0.15s;
  }
  .index-card:hover .index-arrow {
    color: var(--accent);
    transform: translateX(4px);
  }

  @media (max-width: 700px) {
    .index-card { grid-template-columns: 1fr; gap: 0.75rem; }
    .index-arrow { display: none; }
  }
</style>